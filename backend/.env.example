# Backend environment (values are injected by the platform in deployment).
# JWT signing secret — REQUIRED in production. Set a long random value.
JWT_SECRET=change-me-in-production
# SQLAlchemy connection string. Sync psycopg2 driver → postgresql:// scheme.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
# Optional comma-separated CORS allowlist (defaults to * for same-origin/dev).
CORS_ORIGINS=*
